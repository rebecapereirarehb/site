"""
run.py - Ponto de entrada da aplicação Flask
"""
import os
from app import create_app, db
from app.models.user import User, Role
from app.models.activity import ActivityLog

app = create_app(os.environ.get('FLASK_ENV', 'default'))


@app.shell_context_processor
def make_shell_context():
    """Disponibiliza objetos no shell do Flask para debug"""
    return dict(db=db, User=User, Role=Role, ActivityLog=ActivityLog)


@app.cli.command('init-db')
def init_db():
    """Cria as tabelas do banco de dados e dados iniciais"""
    db.create_all()

    # Cria perfis se não existirem
    if not Role.query.filter_by(name='user').first():
        user_role = Role(name='user', description='Usuário comum do sistema')
        db.session.add(user_role)

    if not Role.query.filter_by(name='admin').first():
        admin_role = Role(name='admin', description='Administrador do sistema')
        db.session.add(admin_role)

    db.session.commit()

    # Cria admin padrão se não existir
    if not User.query.filter_by(email='admin@admin.com').first():
        admin_role = Role.query.filter_by(name='admin').first()
        admin = User(
            username='admin',
            full_name='Administrador',
            email='admin@admin.com',
            role=admin_role
        )
        admin.password = 'Admin@123'
        db.session.add(admin)
        db.session.commit()
        print('✅ Admin criado: admin@admin.com / Admin@123')

    print('✅ Banco de dados inicializado com sucesso!')


@app.cli.command('create-admin')
def create_admin():
    """Cria um novo administrador via CLI"""
    import getpass
    print('\n=== Criar Administrador ===')
    username = input('Nome de usuário: ').strip()
    full_name = input('Nome completo: ').strip()
    email = input('E-mail: ').strip()
    password = getpass.getpass('Senha (mín. 8 caracteres): ')

    if len(password) < 8:
        print('❌ Senha muito curta!')
        return

    admin_role = Role.query.filter_by(name='admin').first()
    if not admin_role:
        print('❌ Execute "flask init-db" primeiro.')
        return

    user = User(username=username, full_name=full_name, email=email, role=admin_role)
    user.password = password
    db.session.add(user)
    db.session.commit()
    print(f'✅ Admin "{username}" criado com sucesso!')


if __name__ == '__main__':
    app.run(debug=True)
